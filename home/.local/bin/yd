#!/usr/bin/env lua

local LONELY_FLAGS = { '--only-audio' }

local function includes(table, value)
    for _, tableValue in ipairs(table) do
        if tableValue == value then
            return true
        end
    end

    return false
end

local function getCommandByFlag(flag, value)
    if not value then
        value = ''
    end

    local commands = {
        ['--only-audio'] = '-f bestaudio --extract-audio --audio-format mp3 --audio-quality 0',
        ['--output'] = '--output ' .. value,
        ['-o'] = '--output ' .. value,
    }

    return commands[flag]
end

local function yd(args)
    local cmd = "yt-dlp"
    local url = args[1]


    if not url then
        print('An URL is required')
        return
    end
    table.remove(args, 1)

    -- Handle default case (Video + audio)
    -- if #args == 0 then
    -- end

    local i = 1
    while args[i] do
        if (includes(LONELY_FLAGS, args[i])) then
            cmd = cmd .. ' ' .. getCommandByFlag(args[i])
        else
            cmd = cmd .. ' ' .. getCommandByFlag(args[i], args[i + 1])
            i = i + 1
        end

        i = i + 1
    end

    cmd = cmd .. ' ' .. url

    print('yt-dlp executed:')
    print(cmd)
    os.execute(cmd)
end

yd(arg)
